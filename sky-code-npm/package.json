{
  "name": "sky-code",
  "version": "1.0.0-beta.2",
  "description": "Offline AI coding agent with knowledge graph extraction, powered by Ollama and local LLMs",
  "author": "Sky-Code Team",
  "license": "MIT",
  "private": false,
  "keywords": [
    "ai",
    "coding-assistant",
    "offline",
    "ollama",
    "cli",
    "developer-tools",
    "agent",
    "llm",
    "rust",
    "local-ai",
    "privacy",
    "llama",
    "knowledge-graph",
    "ast",
    "codebase-analysis",
    "refactoring",
    "tree-sitter"
  ],
  "bin": {
    "skycode": "./bin/skycode.js",
    "sky-code": "./bin/skycode.js",
    "sky": "./bin/skycode.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test": "node test/smoke-test.js",
    "doctor": "node lib/doctor.js",
    "serve": "node bin/skycode.js serve"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "binaries/",
    "ui/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  }
}
